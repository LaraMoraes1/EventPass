<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Evento"
            android:textColor="@color/text"
            android:textSize="28sp"
            android:textStyle="bold" />
        <EditText android:id="@+id/nameInput" android:layout_width="match_parent" android:layout_height="52dp" android:hint="Nome" android:textColor="@color/text" android:textColorHint="@color/muted" />
        <EditText android:id="@+id/descInput" android:layout_width="match_parent" android:layout_height="92dp" android:hint="Descrição" android:textColor="@color/text" android:textColorHint="@color/muted" />
        <EditText android:id="@+id/localInput" android:layout_width="match_parent" android:layout_height="52dp" android:hint="Local" android:textColor="@color/text" android:textColorHint="@color/muted" />
        <EditText android:id="@+id/dateInput" android:layout_width="match_parent" android:layout_height="52dp" android:hint="Data: 2026-06-20" android:textColor="@color/text" android:textColorHint="@color/muted" />
        <EditText android:id="@+id/timeInput" android:layout_width="match_parent" android:layout_height="52dp" android:hint="Horário: 19:30" android:textColor="@color/text" android:textColorHint="@color/muted" />
        <EditText android:id="@+id/limitInput" android:layout_width="match_parent" android:layout_height="52dp" android:hint="Limite de participantes" android:inputType="number" android:textColor="@color/text" android:textColorHint="@color/muted" />
        <EditText android:id="@+id/bannerInput" android:layout_width="match_parent" android:layout_height="52dp" android:hint="URL do banner" android:textColor="@color/text" android:textColorHint="@color/muted" />
        <com.google.android.material.button.MaterialButton android:id="@+id/saveButton" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="18dp" android:text="Salvar evento" android:textAllCaps="false" app:cornerRadius="8dp" />
    </LinearLayout>
</ScrollView>
